@model IEnumerable<vinted2.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container py-5">
    <h2 class="mb-4 text-center">My Orders</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">You have no orders yet.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm h-100">
                        @if (order.Product != null)
                        {
                            <!-- Poza produsului -->
                            <img src="@(order.Product.Images?.FirstOrDefault()?.ImagePath
                                             ?? order.Product.ImagePath
                                             ?? "/images/default-product.png")"
                                 class="card-img-top"
                                 alt="@order.Product.Title"
                                 style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <!-- Product deleted placeholder -->
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <div class="text-center text-muted">
                                    <i class="fas fa-box-open fa-3x mb-2"></i>
                                    <p class="mb-0">Product No Longer Available</p>
                                </div>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <!-- Seller Info -->
                            @if (order.Product != null && order.Product.User != null)
                            {
                                <div class="d-flex align-items-center mb-3">
                                    <img src="@(order.Product.User.AvatarPath ?? "/images/profiles/default-avatar.png")"
                                         alt="@(order.Product.User.DisplayName ?? order.Product.User.UserName ?? "Unknown")"
                                         class="rounded-circle me-2"
                                         style="width:40px; height:40px; object-fit:cover;">
                                    <div>
                                        <strong>@(order.Product.User.DisplayName ?? order.Product.User.UserName ?? "Unknown Seller")</strong>
                                        <br>
                                        <small class="text-muted">Seller</small>
                                    </div>
                                </div>
                            }

                            @if (order.Product != null)
                            {
                                <h5 class="card-title">@order.Product.Title</h5>
                            }
                            else
                            {
                                <h5 class="card-title text-muted">Product Deleted</h5>
                                <p class="text-muted small">This product is no longer available</p>
                            }
                            
                            <p class="card-text mb-1">
                                <strong>Price:</strong> @order.Price.ToString("C")
                            </p>
                            <p class="card-text mb-1">
                                <strong>Status:</strong> 
                                <span class="badge 
                                    @(order.Status == vinted2.Models.OrderStatus.Pending ? "bg-warning" :
                                      order.Status == vinted2.Models.OrderStatus.InTransit ? "bg-info" :
                                      order.Status == vinted2.Models.OrderStatus.Completed ? "bg-success" :
                                      "bg-danger")">
                                    @order.Status
                                </span>
                            </p>
                            <p class="card-text text-muted">
                                <small>Ordered at: @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </p>

                            <!-- Action Buttons -->
                            <div class="mt-auto pt-3">
                                @if (order.Status == vinted2.Models.OrderStatus.InTransit)
                                {
                                    <form asp-action="MarkAsReceived" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@order.Id" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success w-100 mb-2">
                                            <i class="fas fa-check-circle"></i> Mark as Received
                                        </button>
                                    </form>
                                }
                                
                                @if (order.Product != null)
                                {
                                    <a href="@Url.Action("Details", "Orders", new { id = order.Id })" class="btn btn-primary w-100 @(order.Status == vinted2.Models.OrderStatus.InTransit ? "" : "mt-2")">
                                        View Details
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-secondary w-100 @(order.Status == vinted2.Models.OrderStatus.InTransit ? "mt-2" : "")" disabled>
                                        Product Unavailable
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
