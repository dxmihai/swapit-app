@{
    ViewData["Title"] = "Order Placed Successfully";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">

            <div class="card shadow-lg border-0">
                <div class="card-body p-5">

                    <div class="mb-4">
                        <i class="fas fa-check-circle text-success" style="font-size: 80px;"></i>
                    </div>

                    <h2 class="mb-3">Thank you for your order!</h2>

                    <p class="text-muted mb-4">
                        Your order has been placed successfully and is now being processed.
                        The seller will prepare the product for shipment.
                    </p>

                    <div class="alert alert-success mb-4">
                        <strong>Delivery details</strong> have been saved successfully.
                        You will be contacted by the courier for delivery.
                    </div>

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Products"
                           asp-action="Index"
                           class="btn btn-primary btn-lg">
                            <i class="fas fa-store"></i> Continue Shopping
                        </a>

                        <a asp-controller="Orders"
                           asp-action="MyOrders"
                           class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-box"></i> View My Orders
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
