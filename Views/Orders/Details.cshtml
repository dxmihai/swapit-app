@model vinted2.Models.Order
@{
    ViewData["Title"] = "Order Details";
    bool isBuyer = ViewBag.IsBuyer ?? false;
    bool isSeller = ViewBag.IsSeller ?? false;
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a></li>
            @if (isBuyer)
            {
                <li class="breadcrumb-item"><a asp-action="MyOrders">My Orders</a></li>
            }
            else if (isSeller)
            {
                <li class="breadcrumb-item"><a asp-action="ManageOrders">Manage Orders</a></li>
            }
            <li class="breadcrumb-item active" aria-current="page">Order #@Model.Id</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <!-- Order Information Card -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-shopping-bag"></i> Order Information</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Order ID:</strong> #@Model.Id
                        </div>
                        <div class="col-md-6">
                            <strong>Order Date:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Status:</strong>
                            <span class="badge 
                                @(Model.Status == vinted2.Models.OrderStatus.Pending ? "bg-warning" :
                                  Model.Status == vinted2.Models.OrderStatus.InTransit ? "bg-info" :
                                  Model.Status == vinted2.Models.OrderStatus.Completed ? "bg-success" :
                                  "bg-danger") fs-6">
                                @Model.Status
                            </span>
                        </div>
                        <div class="col-md-6">
                            <strong>Total Price:</strong> <span class="text-primary fw-bold fs-5">@Model.Price.ToString("C")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Product Information Card -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-box"></i> Product Information</h5>
                </div>
                <div class="card-body">
                    @if (Model.Product != null)
                    {
                        <div class="row">
                            <div class="col-md-4">
                                <img src="@(Model.Product.Images != null && Model.Product.Images.Any() 
                                             ? Model.Product.Images.FirstOrDefault()?.ImagePath 
                                             : Model.Product.ImagePath ?? "/images/default-product.png")"
                                     class="img-fluid rounded"
                                     alt="@Model.Product.Title"
                                     style="max-height: 200px; object-fit: cover;">
                            </div>
                            <div class="col-md-8">
                                <h5>@Model.Product.Title</h5>
                                @if (!string.IsNullOrEmpty(Model.Product.Description))
                                {
                                    <p class="text-muted">@Model.Product.Description</p>
                                }
                                <p><strong>Price:</strong> @Model.Price.ToString("C")</p>
                                @if (Model.Product.Category != null && !string.IsNullOrEmpty(Model.Product.Category.Name))
                                {
                                    <p><strong>Category:</strong> @Model.Product.Category.Name</p>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> This product is no longer available.
                        </div>
                    }
                </div>
            </div>

            <!-- Shipping Information Card -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-truck"></i> Shipping Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <strong>Full Name:</strong><br>
                            @Model.FullName
                        </div>
                        <div class="col-md-6 mb-3">
                            <strong>Phone:</strong><br>
                            @Model.Phone
                        </div>
                        <div class="col-md-12 mb-3">
                            <strong>Address:</strong><br>
                            @Model.Address
                        </div>
                        <div class="col-md-6 mb-3">
                            <strong>City:</strong><br>
                            @Model.City
                        </div>
                        <div class="col-md-6 mb-3">
                            <strong>Delivery Method:</strong><br>
                            @Model.DeliveryMethod
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- User Information Card -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-user"></i> 
                        @if (isBuyer)
                        {
                            <span>Seller Information</span>
                        }
                        else
                        {
                            <span>Buyer Information</span>
                        }
                    </h5>
                </div>
                <div class="card-body text-center">
                    @if (isBuyer && Model.Product?.User != null)
                    {
                        <img src="@(Model.Product.User.AvatarPath ?? "/images/profiles/default-avatar.png")"
                             class="rounded-circle mb-3"
                             alt="@(Model.Product.User.DisplayName ?? Model.Product.User.UserName)"
                             style="width: 100px; height: 100px; object-fit: cover;">
                        <h5>@(Model.Product.User.DisplayName ?? Model.Product.User.UserName)</h5>
                        <p class="text-muted">@Model.Product.User.Email</p>
                    }
                    else if (isSeller && Model.User != null)
                    {
                        <img src="@(Model.User.AvatarPath ?? "/images/profiles/default-avatar.png")"
                             class="rounded-circle mb-3"
                             alt="@(Model.User.DisplayName ?? Model.User.UserName)"
                             style="width: 100px; height: 100px; object-fit: cover;">
                        <h5>@(Model.User.DisplayName ?? Model.User.UserName)</h5>
                        <p class="text-muted">@Model.User.Email</p>
                    }
                </div>
            </div>

            <!-- Action Buttons Card -->
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-cog"></i> Actions</h5>
                </div>
                <div class="card-body">
                    @if (isSeller && Model.Status == vinted2.Models.OrderStatus.Pending)
                    {
                        <form asp-action="MarkAsSent" method="post" class="mb-2">
                            <input type="hidden" name="id" value="@Model.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success w-100">
                                <i class="fas fa-paper-plane"></i> Mark as Sent
                            </button>
                        </form>
                        <form asp-action="CancelOrder" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger w-100" 
                                    onclick="return confirm('Are you sure you want to cancel this order?');">
                                <i class="fas fa-times"></i> Cancel Order
                            </button>
                        </form>
                    }
                    else if (isBuyer && Model.Status == vinted2.Models.OrderStatus.InTransit)
                    {
                        <form asp-action="MarkAsReceived" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success w-100">
                                <i class="fas fa-check-circle"></i> Mark as Received
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <small>
                                @if (Model.Status == vinted2.Models.OrderStatus.Completed)
                                {
                                    <text><i class="fas fa-check-circle"></i> This order has been completed.</text>
                                }
                                else if (Model.Status == vinted2.Models.OrderStatus.Canceled)
                                {
                                    <text><i class="fas fa-ban"></i> This order has been canceled.</text>
                                }
                                else if (Model.Status == vinted2.Models.OrderStatus.InTransit && isSeller)
                                {
                                    <text><i class="fas fa-truck"></i> Order is in transit. Waiting for buyer confirmation.</text>
                                }
                                else if (Model.Status == vinted2.Models.OrderStatus.Pending && isBuyer)
                                {
                                    <text><i class="fas fa-clock"></i> Waiting for seller to process the order.</text>
                                }
                            </small>
                        </div>
                    }
                </div>
            </div>

            <!-- Navigation Card -->
            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    @if (isBuyer)
                    {
                        <a asp-action="MyOrders" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-arrow-left"></i> Back to My Orders
                        </a>
                    }
                    else if (isSeller)
                    {
                        <a asp-action="ManageOrders" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-arrow-left"></i> Back to Manage Orders
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

