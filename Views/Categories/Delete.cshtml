@model vinted2.Models.Category

@{
    ViewData["Title"] = "Delete Category";
    var productCount = Model.Products?.Count ?? 0;
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Delete Category
                    </h3>
                </div>
                <div class="card-body">
                    @if (productCount > 0)
                    {
                        <div class="alert alert-warning">
                            <h5><i class="fas fa-warning"></i> Warning!</h5>
                            <p class="mb-0">
                                This category contains <strong>@productCount product(s)</strong>. 
                                Deleting this category will also delete all associated products permanently.
                            </p>
                        </div>
                    }
                    
                    <h4>Are you sure you want to delete this category?</h4>
                    
                    <div class="category-details">
                        <h5>Category Details:</h5>
                        <dl class="row">
                            <dt class="col-sm-3">Category Name:</dt>
                            <dd class="col-sm-9">
                                <strong>@Html.DisplayFor(model => model.Name)</strong>
                            </dd>
                            <dt class="col-sm-3">Products Count:</dt>
                            <dd class="col-sm-9">
                                <span class="badge @(productCount > 0 ? "bg-warning" : "bg-success")">
                                    @productCount Products
                                </span>
                            </dd>
                        </dl>
                    </div>
                    
                    @if (productCount > 0)
                    {
                        <div class="alert alert-info">
                            <h6><i class="fas fa-info-circle"></i> What will be deleted:</h6>
                            <ul class="mb-0">
                                <li>The category "<strong>@Model.Name</strong>"</li>
                                <li>All @productCount product(s) in this category</li>
                                <li>All associated product images</li>
                            </ul>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <form asp-action="Delete" class="d-inline">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="fas fa-trash"></i> 
                            @if (productCount > 0)
                            {
                                <text>Delete Category & @productCount Product(s)</text>
                            }
                            else
                            {
                                <text>Delete Category</text>
                            }
                        </button>
                    </form>
                    <a asp-action="Index" class="btn btn-secondary btn-lg ms-2">
                        <i class="fas fa-arrow-left"></i> Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
