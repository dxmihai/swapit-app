@model IEnumerable<vinted2.Models.Category>

@{
    ViewData["Title"] = "Manage Categories";
}

<div class="admin-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="admin-title">
                    <i class="fas fa-cog"></i> Manage Categories
                </h1>
                <p class="admin-subtitle">Create and manage product categories</p>
            </div>
            <div class="col-md-4 text-end">
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="fas fa-plus"></i> Create New Category
                </a>
            </div>
        </div>
    </div>
</div>

<div class="categories-management">
    <div class="container">
        @if (Model.Any())
        {
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="category-card">
                            <div class="category-header">
                                <h3 class="category-name">@item.Name</h3>
                            </div>
                            <div class="category-stats">
                                <span class="stat-item">
                                    <i class="fas fa-box"></i> 
                                    @(item.Products?.Count ?? 0) Products
                                </span>
                            </div>
                            <div class="category-actions">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm" title="Edit Category">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm" title="View Details">
                                    <i class="fas fa-eye"></i> Details
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" title="Delete Category">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-tags"></i>
                </div>
                <h3>No Categories Found</h3>
                <p>Create your first category to organize products!</p>
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="fas fa-plus"></i> Create First Category
                </a>
            </div>
        }
    </div>
</div>

